<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>DcsvIo.D2.Encryption</RootNamespace>

    <!-- Emit the SourceGen output (EncryptionDomains.g.cs + EncryptionFrame.g.cs)
         to <project-dir>/Generated/. The directory is tracked in git so PR
         reviewers see codegen diffs without a local build. -->
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>Generated</CompilerGeneratedFilesOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <!--
      The SourceGen pipeline feeds the in-memory compiler with the same content
      that lands on disk under Generated/. Without this Remove, the SDK-default
      <Compile Include="**/*.cs" /> glob picks up the on-disk copy and the build
      fails with duplicate-definition errors (CS0101 / CS0111).
    -->
    <Compile Remove="$(CompilerGeneratedFilesOutputPath)\**\*.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="JetBrains.Annotations" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup>

  <ItemGroup>
    <!--
      EncryptionDomains SourceGen — emits EncryptionDomains.g.cs from
      contracts/encryption-domains/encryption-domains.spec.json. Spec-drives
      the closed catalog of encryption-domain identifiers (audit / notifications
      / courier / plaintext). A typo on a domain identifier surfaces as a
      compile error rather than silently routing to a non-existent keyring.
    -->
    <ProjectReference Include="..\domains-source-gen\DcsvIo.D2.EncryptionDomains.SourceGen.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
    <!--
      EncryptionFrame SourceGen — emits EncryptionFrame.g.cs from
      contracts/encryption-frame/encryption-frame.spec.json. Spec-drives the
      binary frame-layout field-offset + byte-length constants consumed by
      EncryptionFrame.Encode / .Decode. The TS-side decoder in
      @dcsv-io/d2-encryption-abstractions consumes the same spec via
      tools/ts-codegen/src/encryption-frame-emit.ts.
    -->
    <ProjectReference Include="..\frame-source-gen\DcsvIo.D2.EncryptionFrame.SourceGen.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="$(D2PublicContractsRoot)encryption-domains\encryption-domains.spec.json" />
    <AdditionalFiles Include="$(D2PublicContractsRoot)encryption-frame\encryption-frame.spec.json" />
    <!--
      Sealed sibling spec — drives SealedFrameLayout.g.cs (the version-2
      SEALED frame) via SealedFrameGenerator in the same frame-source-gen
      analyzer project. Deliberately a SEPARATE spec file from
      encryption-frame.spec.json so the version-1 catalog + its generated
      artifacts stay byte-identical while the sealed layout evolves.
    -->
    <AdditionalFiles Include="$(D2PublicContractsRoot)encryption-frame-sealed\encryption-frame-sealed.spec.json" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\utilities\DcsvIo.D2.Utilities.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="DcsvIo.D2.Tests" />
    <InternalsVisibleTo Include="DcsvIo.D2.Private.Packages.Tests" />
  </ItemGroup>

  <!-- Publish metadata (per-package semver + NuGet identity). -->
  <PropertyGroup>
    <Version>0.1.1</Version>
    <PackageId>DcsvIo.D2.Encryption</PackageId>
    <Description>AES-256-GCM payload encryption with a JWKS-style multi-kid keyring for D2 — a pure crypto primitive decoupled from key sources.</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
