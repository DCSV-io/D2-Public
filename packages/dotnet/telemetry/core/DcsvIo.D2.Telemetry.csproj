<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <RootNamespace>DcsvIo.D2.Telemetry</RootNamespace>
    <!--
      Sdk.Web defaults OutputType to Exe (intended for runnable web apps);
      explicit Library override since this is a shared library, NOT an app
      entry point. Sdk.Web is preferred over plain Sdk because it brings the
      AspNetCore framework reference automatically — MapD2PrometheusEndpoint
      needs Microsoft.AspNetCore.Routing.IEndpointRouteBuilder + the
      OpenTelemetry.Exporter.Prometheus.AspNetCore extension method
      MapPrometheusScrapingEndpoint(). Plain Sdk + a manual FrameworkReference
      would be functionally equivalent but not the modern convention
      (matches sibling DcsvIo.D2.Logging + DcsvIo.D2.AspNetCore csproj;
      monorepo-private DcsvIo.D2.Private.Auth.Http PackageId same Sdk.Web shape).
    -->
    <OutputType>Library</OutputType>
  </PropertyGroup>

  <!--
    DcsvIo.D2.Telemetry — OpenTelemetry SDK setup + OTLP exporters
    (traces / metrics / logs) + IP-restricted Prometheus scraping endpoint
    + aggregation of every shipped shared lib's ActivitySource + Meter into
    a single AddD2Telemetry() call. Foundation lib that the composition-root
    aggregator and per-service Program.cs files call to wire the OTel SDK
    without each service duplicating ~120 lines of OTel SDK boilerplate.

    Independent of DcsvIo.D2.Logging — Logging owns Serilog + the
    [RedactData] enforcement pipeline; Telemetry owns the OTel SDK.
    The two libs cooperate at runtime via the MEL bridge (Serilog's
    writeToProviders: true routes through the OTLP log exporter Telemetry
    registers as an ILoggerProvider) without either lib referencing the
    other at compile time.

    Does NOT own:
      • [RedactData] discipline             — DcsvIo.D2.Logging owns it.
      • [LoggerMessage] delegates           — bootstrapping the OTel logs
                                              MEL provider during MEL
                                              bootstrap is circular.
      • Serilog configuration / sinks       — DcsvIo.D2.Logging owns them.
      • Self-monitoring (export-failure     — OTel SDK's own internal
        counters)                             diagnostics suffice for the
                                              foundation tier; consumers
                                              wire EventListener if they
                                              want lib-internal export
                                              failure visibility.
  -->

  <ItemGroup>
    <PackageReference Include="JetBrains.Annotations" />
    <!--
      OpenTelemetry.Api — surgical 1.15.3 override per
      GHSA-g94r-2vxg-569j (advisories on the 1.15.0 line). Direct ref
      required to override the transitive 1.15.0 pulled by the
      Instrumentation.* packages.
    -->
    <PackageReference Include="OpenTelemetry.Api" />
    <!--
      OpenTelemetry — core SDK (OpenTelemetryBuilder, BatchExportProcessor,
      etc.). Listed explicitly for visibility (transitive otherwise).
    -->
    <PackageReference Include="OpenTelemetry" />
    <!--
      OpenTelemetry.Extensions.Hosting — services.AddOpenTelemetry() +
      WithTracing / WithMetrics / WithLogging overloads.
    -->
    <PackageReference Include="OpenTelemetry.Extensions.Hosting" />
    <!--
      OpenTelemetry.Exporter.OpenTelemetryProtocol — surgical 1.15.3
      override per GHSA-mr8r-92fq-pj8p + GHSA-q834-8qmm-v933. OTLP
      HTTP/Protobuf exporter for traces / metrics / logs.
    -->
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" />
    <!--
      OpenTelemetry.Exporter.Prometheus.AspNetCore — pinned at 1.15.0-beta.1
      per v1 baseline (the Prometheus exporter is a long-running beta in
      OTel .NET; >18mo of v1 production stability supports the pin).
      Required for MapPrometheusScrapingEndpoint.
    -->
    <PackageReference Include="OpenTelemetry.Exporter.Prometheus.AspNetCore" />
    <!--
      OpenTelemetry.Instrumentation.AspNetCore — inbound HTTP request spans
      + metrics. Filter callback excludes infrastructure paths.
    -->
    <PackageReference Include="OpenTelemetry.Instrumentation.AspNetCore" />
    <!--
      OpenTelemetry.Instrumentation.GrpcNetClient — outbound gRPC client
      spans. Pinned at 1.15.0-beta.1 per v1 baseline.
    -->
    <PackageReference Include="OpenTelemetry.Instrumentation.GrpcNetClient" />
    <!--
      OpenTelemetry.Instrumentation.Http — outbound HttpClient spans +
      metrics. FilterHttpRequestMessage callback excludes self-referential
      OTLP exporter calls (prevents infinite-loop instrumentation).
    -->
    <PackageReference Include="OpenTelemetry.Instrumentation.Http" />
    <!--
      OpenTelemetry.Instrumentation.Process — process metrics
      (CPU, memory, fd count). Pinned at 1.15.0-beta.1 per v1 baseline.
    -->
    <PackageReference Include="OpenTelemetry.Instrumentation.Process" />
    <!--
      OpenTelemetry.Instrumentation.Runtime — .NET runtime metrics
      (GC, threadpool, JIT).
    -->
    <PackageReference Include="OpenTelemetry.Instrumentation.Runtime" />
    <!--
      Microsoft.Extensions.{DependencyInjection,Logging,Options,Configuration,Hosting}.Abstractions
      are NOT listed — Microsoft.NET.Sdk.Web's framework reference
      (Microsoft.AspNetCore.App) ships them; explicit references trigger
      NU1510. Versions are still pinned via Directory.Packages.props.
    -->
  </ItemGroup>

  <ItemGroup>
    <!--
      utilities — Falsey() / Truthy() / ToNullIfEmpty() string extensions
      consumed by options validation + env-var resolution.
    -->
    <ProjectReference Include="..\..\utilities\DcsvIo.D2.Utilities.csproj" />
    <!--
      aspnetcore — canonical InfrastructurePathMatcher (consumed by the
      AspNetCore-instrumentation Filter callback to suppress auto-spans
      for infrastructure paths) + D2AspNetCoreConstants (re-pointed
      HEALTH_ENDPOINT_PATH / ALIVE_ENDPOINT_PATH / METRICS_ENDPOINT_PATH /
      WELL_KNOWN_ENDPOINT_PATH constants + DEFAULT_INFRASTRUCTURE_PATHS).
    -->
    <ProjectReference Include="..\..\aspnetcore\DcsvIo.D2.AspNetCore.csproj" />
    <!--
      handler — HandlerTelemetry.SourceName const referenced by the
      AggregatedTelemetrySources registration table.
    -->
    <ProjectReference Include="..\..\handler\core\DcsvIo.D2.Handler.csproj" />
    <!--
      Auth runtime + Auth.Outbound are private composition packages.
      AggregatedTelemetrySources pins their OTel wire names as string
      literals (AUTH_WIRE_NAME / AUTH_OUTBOUND_WIRE_NAME) — no ProjectReference
      into demoted Auth (public Telemetry must build on Public.slnx alone).
    -->
    <!--
      messaging\rabbitmq — MessagingTelemetry.SOURCE_NAME const referenced
      by the AggregatedTelemetrySources registration table.
    -->
    <ProjectReference Include="..\..\messaging\rabbitmq\DcsvIo.D2.Messaging.RabbitMq.csproj" />
    <!--
      caching-distributed-redis — RedisCacheTelemetry.METER_NAME const
      referenced by the AggregatedTelemetrySources registration table.
    -->
    <ProjectReference Include="..\..\caching\distributed-redis\DcsvIo.D2.Caching.Distributed.Redis.csproj" />
    <!--
      caching-local-default — LocalCacheTelemetry.METER_NAME const
      referenced by the AggregatedTelemetrySources registration table.
    -->
    <ProjectReference Include="..\..\caching\local-default\DcsvIo.D2.Caching.Local.Default.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="DcsvIo.D2.Tests" />
    <InternalsVisibleTo Include="DcsvIo.D2.Private.Packages.Tests" />
  </ItemGroup>

  <!-- Publish metadata (per-package semver + NuGet identity). -->
  <PropertyGroup>
    <Version>0.1.1</Version>
    <PackageId>DcsvIo.D2.Telemetry</PackageId>
    <Description>OpenTelemetry SDK setup for D2 — traces, metrics, logs, OTLP exporters, an IP-restricted Prometheus endpoint, and aggregation of every shared library's ActivitySource and Meter.</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
