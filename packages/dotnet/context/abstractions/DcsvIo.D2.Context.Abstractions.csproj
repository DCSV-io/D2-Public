<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>DcsvIo.D2.Context.Abstractions</RootNamespace>

    <!-- Emit the generator's output (IRequestContext.g.cs, MutableRequestContext.g.cs,
         PropagatedContext.g.cs, PropagatedContextExtensions.g.cs,
         PropagatedContextSerializer.g.cs) to <project-dir>/Generated/. The
         directory is tracked in git so PR reviewers see codegen diffs without
         a local build. -->
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>Generated</CompilerGeneratedFilesOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <!--
      The SourceGen pipeline feeds the in-memory compiler with the same content
      that lands on disk under Generated/. Without this Remove, the SDK-default
      <Compile Include="**/*.cs" /> glob picks up the on-disk copy and the build
      fails with duplicate-definition errors (CS0101 / CS0111). See:
      https://learn.microsoft.com/dotnet/core/project-sdk/msbuild-props#compilergeneratedfilesoutputpath
    -->
    <Compile Remove="$(CompilerGeneratedFilesOutputPath)\**\*.cs" />
  </ItemGroup>

  <!--
    Single-lib home for every spec-driven context primitive. Codegen-emitted
    from contracts/{auth,request}-context/*.spec.json by
    DcsvIo.D2.Context.SourceGen:

      • IRequestContext.g.cs        — read-only interface (extends IAuthContext)
      • MutableRequestContext.g.cs  — settable concrete; per-scope DI singleton
      • PropagatedContext.g.cs      — record carrying the propagate=true subset
      • PropagatedContextExtensions.g.cs — IRequestContext ↔ record projections
      • PropagatedContextSerializer.g.cs — base64url + JSON codec with per-field
                                            maxLength validation from the spec

    Hand-written helpers (RFC-spec'd parsers, not D2-spec'd) ship here too:

      • ActorChainParser     — RFC 8693 §4.1 strict-mode 'act' claim parser
      • ScopeClaimParser     — RFC 6749 §3.3 SP-only 'scope' claim parser
      • MalformedActorChainException

    Transport-specific filling extensions (HTTP, gRPC, AMQP) live in their
    own libs and consume this assembly's primitives.
  -->

  <ItemGroup>
    <!--
      JetBrains.Annotations — [MustDisposeResource] on ISystemWorkScopeFactory.BeginAsync
      (caller-owned IAsyncDisposable scope; inspectcode leak detection).
    -->
    <PackageReference Include="JetBrains.Annotations" />
    <!--
      Microsoft.Extensions.DependencyInjection.Abstractions — the System worker
      establishment bootstrap (SystemRequestContextBootstrap) resolves the scope's
      MutableRequestContext via GetRequiredService<T>(). Zero-runtime-cost abstractions
      package; this is a plain Sdk lib (no AspNetCore framework reference) so the
      explicit PackageReference does not trigger NU1510.
    -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <!--
      Microsoft.Extensions.Logging.Abstractions — carries the ILogger<T> type + the
      [LoggerMessage] source generator, consumed by SystemRequestContextBootstrapLog for
      the System establishment boundary's Debug-level trace (SystemRequestContextBootstrap
      resolves ILogger<T> from the scope's IServiceProvider it already receives — no new
      DI surface). Same NU1510 reasoning as the DependencyInjection.Abstractions reference
      above.
    -->
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <!--
      Microsoft.Extensions.Options — IOptions&lt;D2WorkloadIdentityOptions&gt; for
      SystemWorkScopeFactory (host service id stamped onto RequestOrigin.System).
      Plain Sdk lib; explicit package ref (no AspNetCore framework reference).
    -->
    <PackageReference Include="Microsoft.Extensions.Options" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\auth\context-abstractions\DcsvIo.D2.AuthContext.Abstractions.csproj" />
    <ProjectReference Include="..\..\auth\abstractions\DcsvIo.D2.Auth.Abstractions.csproj" />
    <ProjectReference Include="..\..\utilities\DcsvIo.D2.Utilities.csproj" />
    <!--
      time — IClock injection seam used by the InProcessModule + System establishment
      boundaries to timestamp the call-path entry they append (Instant → DateTimeOffset
      wire form). Foundation lib (NodaTime + Result/I18n/Utilities); no cycle.
    -->
    <ProjectReference Include="..\..\time\DcsvIo.D2.Time.csproj" />
    <ProjectReference Include="..\source-gen\DcsvIo.D2.Context.SourceGen.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="$(D2PublicContractsRoot)auth-context\IAuthContext.spec.json" />
    <AdditionalFiles Include="$(D2PublicContractsRoot)request-context\IRequestContext.spec.json" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="DcsvIo.D2.Tests" />
    <InternalsVisibleTo Include="DcsvIo.D2.Private.Packages.Tests" />
  </ItemGroup>

  <!-- Publish metadata (per-package semver + NuGet identity). -->
  <PropertyGroup>
    <Version>0.1.1</Version>
    <PackageId>DcsvIo.D2.Context.Abstractions</PackageId>
    <Description>Spec-driven request-context primitives for D2 — IRequestContext, MutableRequestContext, and the cross-hop propagation codecs.</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
