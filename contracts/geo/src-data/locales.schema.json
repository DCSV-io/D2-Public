{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.d2.dcsv.io/contracts/geo/src-data/locales.schema.json",
  "title": "Locale catalog (pipeline-raw)",
  "description": "Tier 1 (pipeline-raw) locale catalog produced by the geo data pipeline Verbose with per-entry _provenance + diagnostics including tagShape + derivedDefaultRegionTags. NOT directly consumed by codegen — see ../locales.schema.json for the Tier 2 shape.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "$schema",
    "$note",
    "catalogVersion",
    "generatedAt",
    "sources",
    "fieldCoverage",
    "entries"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "$note": { "type": "string" },
    "catalogVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.]+)?$"
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "sources": { "$ref": "#/$defs/Sources" },
    "fieldCoverage": { "$ref": "#/$defs/FieldCoverage" },
    "tagShape": {
      "type": "object",
      "description": "Optional diagnostic — distribution of locale tag shapes (bareLanguage / languageRegion / languageScriptRegion / languageScript / other).",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "derivedDefaultRegionTags": {
      "type": "integer",
      "description": "Optional diagnostic — count of lang-Region tags derived via CLDR likelySubtags (NOT in availableLocales.json directly).",
      "minimum": 0
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["ietfBcp47Tag"],
        "properties": {
          "ietfBcp47Tag": { "type": "string", "minLength": 2 }
        }
      }
    }
  },
  "$defs": {
    "Sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "url", "license", "fetchedAt", "sha256"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "license": { "type": "string" },
          "fetchedAt": { "type": "string", "format": "date-time" },
          "sha256": {
            "description": "SHA-256 hex digest of the fetched upstream body, OR a runtime-version placeholder (e.g. node-24.14.0) when the source is a built-in runtime data set with no fetched file to hash.",
            "type": "string",
            "anyOf": [
              { "pattern": "^[a-f0-9]{64}$" },
              { "pattern": "^node-\\d+\\.\\d+\\.\\d+$" }
            ]
          }
        }
      }
    },
    "FieldCoverage": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["populated", "total", "pct"],
        "properties": {
          "populated": { "type": ["integer", "number"], "minimum": 0 },
          "total": { "type": "integer", "minimum": 0 },
          "pct": { "type": "string", "pattern": "^\\d+\\.\\d+%$" }
        }
      }
    }
  }
}
