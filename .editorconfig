# -----------------------------------------------------------------------

root = true

# Default for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# TypeScript / JavaScript / Svelte
[*.{ts,js,mjs,cjs,mts,cts,svelte}]
indent_style = space
indent_size = 2

# JSON / YAML
[*.{json,yaml,yml}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false

# C#
[*.cs]
indent_style = space
indent_size = 4

# Promote all analyzer diagnostics to warning (visible in build + Rider)
dotnet_analyzer_diagnostic.severity = warning

# SA1633: File should have header
dotnet_diagnostic.SA1633.severity = warning

# SA1101: Prefix local calls with 'this'
dotnet_diagnostic.SA1101.severity = none

# SA1135: Qualified using directives
# dotnet_diagnostic.SA1135.severity = none

# Prefer simple names
dotnet_diagnostic.IDE0001.severity = warning

# IDE0065: project convention is `namespace` FIRST, then `using` directives.
# For file-scoped namespaces, "inside_namespace" means usings come AFTER the
# namespace declaration. This enforces the project convention that namespace
# comes first, then using directives — never the other way around.
csharp_using_directive_placement = inside_namespace

# IDE0036 / R# "Modifiers Order": match StyleCop SA1206 ordering — access keyword
# first, then `static`, then `new` and other modifiers. R# defaults to
# `public new static`, which conflicts with SA1206's `public static new`.
# Setting this explicitly makes both Roslyn IDE0036 and JetBrains R# agree
# with StyleCop and stops the "inconsistent modifier order" warning.
csharp_preferred_modifier_order = public, private, protected, internal, file, static, extern, new, virtual, abstract, sealed, override, readonly, unsafe, required, volatile, async:warning

# SA1310: Field names should not contain underscore
dotnet_diagnostic.SA1310.severity = none

# SA1300: Field names should not begin with underscore
dotnet_diagnostic.SA1309.severity = none

# SA1124: Do not use regions
dotnet_diagnostic.SA1124.severity = none

# SA1601: Partial elements should be documented
dotnet_diagnostic.SA1601.severity = none

# SA1615: Element return value should be documented
# Suppressed — for factory methods, fluent-API methods, and obvious-projection
# extensions, the return value is fully implied by the method name + <summary>.
# Forcing a `<returns>A new D2Result instance.</returns>` after every factory
# is noise without semantic value. CS1591 still enforces that every public
# member has a `<summary>`, which is where the actual documentation lives.
dotnet_diagnostic.SA1615.severity = none

# SA1619: Generic, partial element should include type parameter documentation
# Suppressed — when a generic type is split across multiple partial files
# (e.g. D2Result.Generic.cs / D2Result.Generic.Factories.cs / D2Result.Generic.Monadic.cs),
# the type-parameter <typeparam> doc lives on the main partial declaration only.
# Repeating it on every partial is noise; SA1601 is already suppressed for the
# same reason at the type-summary level.
dotnet_diagnostic.SA1619.severity = none

# SA1308: Variable names should not be prefixed (project uses s_ for mutable static, sr_ for static readonly)
dotnet_diagnostic.SA1308.severity = none

# SA1311: Some silly naming crap
dotnet_diagnostic.SA1311.severity = none

# CA2007: Do not directly await a Task without ConfigureAwait
# Not needed in ASP.NET Core (no sync context)
dotnet_diagnostic.CA2007.severity = none

# SA1118: Parameter should not span multiple lines
dotnet_diagnostic.SA1118.severity = none

# CA1716: Identifiers should not match keywords (e.g. namespace segments like "Shared")
dotnet_diagnostic.CA1716.severity = none

# CA1707: Identifiers should not contain underscores (test method naming convention uses them)
dotnet_diagnostic.CA1707.severity = none

# CA1861: Prefer static readonly fields over constant array arguments (mostly test [InlineData])
dotnet_diagnostic.CA1861.severity = none

# SA1503: Braces should not be omitted (single-statement if/else/for/while/etc.)
# Project convention: brace-less form is allowed when the line BEFORE the
# statement is blank or a comment, AND the line AFTER is blank. This visually
# isolates the guarded statement and reduces boilerplate around early-return
# guards. Where the surrounding context is dense (no blank/comment buffer),
# braces remain to preserve scan readability.
dotnet_diagnostic.SA1503.severity = none

# SA1642: Constructor summary should begin with rigid "Initializes a new
# instance of the X class." text. Project preference: ctor docs read as
# natural prose explaining intent / behavior / parameter semantics rather
# than echoing the boilerplate template.
dotnet_diagnostic.SA1642.severity = none

# CA1000: Do not declare static members on generic types (D2Result<T> factory pattern)
dotnet_diagnostic.CA1000.severity = none

# CA1859: Use concrete types for performance (interfaces are intentional for DI/testability)
dotnet_diagnostic.CA1859.severity = none

# CA1708: Identifiers should differ by more than case (TLC namespace convention)
dotnet_diagnostic.CA1708.severity = none

# CA1873: Avoid unnecessary logging calls (false positives on Moq test predicates)
dotnet_diagnostic.CA1873.severity = none

# CA1068: CancellationToken should be last parameter (BaseHandler design — ct is passed far more often than options)
dotnet_diagnostic.CA1068.severity = none

# ReSharper: Partial type with single part (intentional — scaffolding for future extension per convention)
# Intentional full-qualified targets in file-scoped `using H = …IHandler` aliases
# (§5.29). Without this, clean CI checkouts flood "Qualifier is redundant" at WARNING.
resharper_redundant_name_qualifier_highlighting = none

resharper_partial_type_with_single_part_highlighting = none

# ReSharper: Positional property never accessed (consumed via serialization, proto mapping, destructuring)
resharper_not_accessed_positional_property_global_highlighting = none

# ReSharper: Auto-property accessor never used (set by JSON deserialization or config binding)
resharper_unused_auto_property_accessor_global_highlighting = none

# ReSharper: Inconsistent modifiers declaration order — R# enforces its own modifier
# ordering ("public new static") that conflicts with StyleCop SA1206
# ("public static new"). Project chose to follow StyleCop; SA1206 is enforced at
# build time via TreatWarningsAsErrors, so R#'s parallel check is redundant.
resharper_arrange_modifiers_order_highlighting = none

# ReSharper: Inconsistent naming — R#'s default rule wants PascalCase for non-private
# constants ("NotFound"), but project convention is UPPER_CASE
# ("NOT_FOUND"). The dotnet_naming_rule above ("public_constants_must_be_upper_case")
# enforces UPPER_CASE at the Roslyn analyzer level (build-enforced); suppress R#'s
# parallel inspection that uses its own naming rules.
resharper_inconsistent_naming_highlighting = none

# Global usings are top-level by C# language rule (they cannot be nested inside a
# namespace), so the inside-namespace placement convention cannot apply to them.
# Hand-written GlobalUsings.cs files are therefore exempt from SA1200 / IDE0065.
[**/GlobalUsings.cs]
csharp_using_directive_placement = outside_namespace
dotnet_diagnostic.SA1200.severity = none

# EF Core migrations are reproducible generated output (`dotnet ef migrations add`),
# never hand-authored — exclude them from style analysis. Real compile errors still surface.
[**/Migrations/*.cs]
generated_code = true

# Protoc / Grpc.Tools output (the message C# generated from the shared .proto
# files into obj/<Config>/<TFM>/) carries oblivious — un-annotated — reference
# types because Google.Protobuf does not emit nullable annotations. That trips
# the PublicApiAnalyzers RS0041 ("uses some oblivious reference types") rule on
# the generated public proto types, which are part of the published surface but
# whose nullability we do not author. Disable RS0041 for the generated proto
# C# only; the API-recording rules (RS0016 new-API / RS0017 removed-API) still
# run, so the proto-derived public surface is still tracked in PublicAPI.*.txt.
[**/obj/**/*.cs]
dotnet_diagnostic.RS0041.severity = none
