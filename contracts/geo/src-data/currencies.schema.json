{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.d2.dcsv.io/contracts/geo/src-data/currencies.schema.json",
  "title": "Currency catalog (pipeline-raw)",
  "description": "Tier 1 (pipeline-raw) currency catalog produced by private/tools/geo-data-pipeline. Verbose with per-entry _provenance + diagnostics. Includes both active and retired currencies. NOT directly consumed by codegen — see ../currencies.schema.json for the Tier 2 shape.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "$schema",
    "$note",
    "catalogVersion",
    "generatedAt",
    "sources",
    "fieldCoverage",
    "entries"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "$note": { "type": "string" },
    "catalogVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.]+)?$"
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "sources": { "$ref": "#/$defs/Sources" },
    "fieldCoverage": { "$ref": "#/$defs/FieldCoverage" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["iso4217AlphaCode", "displayName"],
        "properties": {
          "iso4217AlphaCode": { "type": "string", "pattern": "^[A-Z]{3}$" },
          "displayName": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "Sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "url", "license", "fetchedAt", "sha256"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "license": { "type": "string" },
          "fetchedAt": { "type": "string", "format": "date-time" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "FieldCoverage": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["populated", "total", "pct"],
        "properties": {
          "populated": { "type": "integer", "minimum": 0 },
          "total": { "type": "integer", "minimum": 0 },
          "pct": { "type": "string", "pattern": "^\\d+\\.\\d+%$" }
        }
      }
    }
  }
}
