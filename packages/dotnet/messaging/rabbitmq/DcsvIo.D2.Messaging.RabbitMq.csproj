<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>DcsvIo.D2.Messaging.RabbitMq</RootNamespace>

    <!-- Emit codegen output (MessagingActivityTags.g.cs + DlqFailureCauses.g.cs)
         to <project-dir>/Generated/. The directory is tracked in git so PR
         reviewers see codegen diffs without a local build. -->
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>Generated</CompilerGeneratedFilesOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <!--
      The SourceGen pipeline feeds the in-memory compiler with the same content
      that lands on disk under Generated/. Without this Remove, the SDK-default
      <Compile Include="**/*.cs" /> glob picks up the on-disk copy and the build
      fails with duplicate-definition errors (CS0101 / CS0111). See:
      https://learn.microsoft.com/dotnet/core/project-sdk/msbuild-props#compilergeneratedfilesoutputpath
    -->
    <Compile Remove="$(CompilerGeneratedFilesOutputPath)\**\*.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="JetBrains.Annotations" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
    <PackageReference Include="RabbitMQ.Client" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\abstractions\DcsvIo.D2.Messaging.Abstractions.csproj" />
    <ProjectReference Include="..\..\encryption\core\DcsvIo.D2.Encryption.csproj" />
    <ProjectReference Include="..\..\caching\abstractions\DcsvIo.D2.Caching.Abstractions.csproj" />
    <ProjectReference Include="..\..\handler\core\DcsvIo.D2.Handler.csproj" />
    <!--
      context\abstractions provides MutableRequestContext, IRequestContext,
      PropagatedContext (record), PropagatedContextExtensions (projections),
      PropagatedContextSerializer (codec) — every spec-driven primitive the
      consumer-side scope registration + producer-side propagation header
      need. The wire body itself carries no envelope; these are scoped
      per-message defaults.
    -->
    <ProjectReference Include="..\..\context\abstractions\DcsvIo.D2.Context.Abstractions.csproj" />
    <ProjectReference Include="..\..\resilience\DcsvIo.D2.Resilience.csproj" />
    <ProjectReference Include="..\..\result\core\DcsvIo.D2.Result.csproj" />
    <ProjectReference Include="..\..\utilities\DcsvIo.D2.Utilities.csproj" />
    <ProjectReference Include="..\..\i18n\abstractions\DcsvIo.D2.I18n.Abstractions.csproj" />
    <ProjectReference Include="..\..\i18n\keys\DcsvIo.D2.I18n.Keys.csproj" />
    <!--
      headers\amqp — codegen-emitted AMQP wire-protocol header constants
      (AmqpHeaders.MESSAGE_ID, .ENCRYPTION_KID, .TRACEPARENT, .PROPAGATED_CONTEXT, ...)
      — a typo on a header name surfaces as a compile error rather than silently
      routing to a wrong header.
    -->
    <ProjectReference Include="..\..\headers\amqp\DcsvIo.D2.Headers.Amqp.csproj" />
    <!--
      OtelMessagingTags SourceGen — emits MessagingActivityTags.g.cs from
      contracts/otel-messaging-tags/otel-messaging-tags.spec.json. Spec-drives
      the OTel sem-conv attribute names emitted on publisher + consumer spans
      so the two sides STRUCTURALLY cannot drift from the standard.
    -->
    <ProjectReference Include="..\otel-messaging-tags-source-gen\DcsvIo.D2.OtelMessagingTags.SourceGen.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
    <!--
      DlqFailureMetadata SourceGen — multi-target dispatch. The Causes-half
      emits into this csproj (DlqFailureCauses.g.cs) since DlqFailureHeaderBuilder
      lives here; the Fields-half emits into abstractions
      (DlqFailureMetadataFields.g.cs).
    -->
    <ProjectReference Include="..\dlq-failure-metadata-source-gen\DcsvIo.D2.Messaging.DlqMetadata.SourceGen.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="$(D2PublicContractsRoot)otel-messaging-tags\otel-messaging-tags.spec.json" />
    <AdditionalFiles Include="$(D2PublicContractsRoot)dlq-failure-metadata\dlq-failure-metadata.spec.json" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="DcsvIo.D2.Tests" />
    <InternalsVisibleTo Include="DcsvIo.D2.Private.Packages.Tests" />
    <!--
      The Edge test tree hosts the sealed-messaging headline integration proof, whose
      fixture message types register their descriptors through the internal
      MessageWireResolver.RegisterForTesting seam (the production registry carries only
      real spec messages).
    -->
    <InternalsVisibleTo Include="DcsvIo.D2.Private.Edge.Tests" />
  </ItemGroup>

  <!-- Publish metadata (per-package semver + NuGet identity). -->
  <PropertyGroup>
    <Version>0.1.1</Version>
    <PackageId>DcsvIo.D2.Messaging.RabbitMq</PackageId>
    <Description>Default RabbitMQ implementation of the D2 messaging abstractions — publishing, subscribing, encryption frames, and dead-letter handling.</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
