{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.d2.dcsv.io/contracts/geo/overlays/countries.overlays.schema.json",
  "title": "Country catalog overlays (trackable manual patches)",
  "description": "Hand-rolled overlay file applied at Tier 2 build time on top of Tier 1 src-data. Used to inject entities that upstream sources (datasets/country-codes / CLDR / etc.) omit but the platform needs (e.g., disputed-status territories like Kosovo) AND to override / remove specific entries when upstream is wrong. Each entry carries a `reason` + `addedAt` so the policy decision is audit-trail visible. The Tier 2 builder loads overlays after Tier 1 src-data and merges them in before running cross-catalog M:M backfill.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$generated",
    "$source",
    "$schema",
    "$note",
    "catalogVersion",
    "lastEditedAt",
    "additions",
    "overrides",
    "removals"
  ],
  "properties": {
    "$generated": { "const": false },
    "$source": { "const": "manual-overlay" },
    "$schema": { "type": "string" },
    "$note": { "type": "string" },
    "catalogVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.]+)?$"
    },
    "lastEditedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "additions": {
      "type": "array",
      "description": "Countries to ADD that aren't in Tier 1 src-data. Each entry's `data` must match the Tier 1 SrcDataCountry shape (the Tier 2 builder handles cross-catalog M:M backfill + denormalization).",
      "items": { "$ref": "#/$defs/AdditionEntry" }
    },
    "overrides": {
      "type": "array",
      "description": "Field-level patches to existing Tier 1 entries. Use sparingly — prefer fixing upstream when possible.",
      "items": { "$ref": "#/$defs/OverrideEntry" }
    },
    "removals": {
      "type": "array",
      "description": "Tier 1 entries to drop from the Tier 2 output. Use rarely — usually a sign the upstream source has a wrong entry we don't want to ship.",
      "items": { "$ref": "#/$defs/RemovalEntry" }
    }
  },
  "$defs": {
    "TrackingMetadata": {
      "type": "object",
      "description": "Provenance fields every overlay entry MUST carry.",
      "required": ["id", "addedAt", "reason"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Primary key of the targeted entry (ISO 3166-1 alpha-2 for countries). For additions, this is the new entity's identifier; for overrides/removals, it matches an existing Tier 1 entry."
        },
        "addedAt": {
          "type": "string",
          "description": "ISO 8601 date (YYYY-MM-DD) when this overlay entry was added. Used for audit ordering.",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "reason": {
          "type": "string",
          "description": "Human-readable policy decision behind this entry. Required — future maintainers + auditors must be able to see WHY we hand-rolled this without git-archaeology.",
          "minLength": 20
        },
        "addedBy": {
          "type": "string",
          "description": "Optional context: who made this decision (person / role / commit / decision-review date)."
        }
      }
    },
    "AdditionEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "addedAt", "reason", "data"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Z]{2}$" },
        "addedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "reason": { "type": "string", "minLength": 20 },
        "addedBy": { "type": "string" },
        "data": {
          "type": "object",
          "description": "Full Tier 1 SrcDataCountry shape. The Tier 2 builder ingests this exactly as if it had come from Tier 1 src-data, then runs the standard cross-catalog M:M backfill + denormalization pipeline.",
          "additionalProperties": false,
          "required": [
            "iso31661Alpha2Code",
            "displayName",
            "officialName",
            "firstDayOfWeek",
            "weekendStart",
            "weekendEnd",
            "measurementSystem"
          ],
          "properties": {
            "iso31661Alpha2Code": { "type": "string", "pattern": "^[A-Z]{2}$" },
            "iso31661Alpha3Code": {
              "type": ["string", "null"],
              "pattern": "^[A-Z]{3}$"
            },
            "iso31661NumericCode": {
              "type": ["string", "null"],
              "pattern": "^\\d{3}$"
            },
            "displayName": { "type": "string", "minLength": 1 },
            "officialName": { "type": "string", "minLength": 1 },
            "endonymDisplayName": { "type": ["string", "null"] },
            "sovereignCountryISO31661Alpha2Code": {
              "type": ["string", "null"],
              "pattern": "^[A-Z]{2}$"
            },
            "phoneNumberPrefix": { "type": ["string", "null"] },
            "phoneNumberNationalFormat": { "type": ["string", "null"] },
            "phoneNumberMinDigits": {
              "type": ["integer", "null"],
              "minimum": 1,
              "maximum": 17
            },
            "phoneNumberMaxDigits": {
              "type": ["integer", "null"],
              "minimum": 1,
              "maximum": 17
            },
            "phoneNumberInternationalPrefix": { "type": ["string", "null"] },
            "phoneNumberNationalPrefix": { "type": ["string", "null"] },
            "primaryCurrencyISO4217AlphaCode": {
              "type": ["string", "null"],
              "pattern": "^[A-Z]{3}$"
            },
            "primaryLanguageISO6391Code": {
              "type": ["string", "null"],
              "pattern": "^[a-z]{2}$"
            },
            "primaryLocaleIETFBCP47Tag": { "type": ["string", "null"] },
            "firstDayOfWeek": {
              "type": "string",
              "enum": [
                "Sunday",
                "Monday",
                "Tuesday",
                "Wednesday",
                "Thursday",
                "Friday",
                "Saturday"
              ]
            },
            "weekendStart": {
              "type": "string",
              "enum": [
                "Sunday",
                "Monday",
                "Tuesday",
                "Wednesday",
                "Thursday",
                "Friday",
                "Saturday"
              ]
            },
            "weekendEnd": {
              "type": "string",
              "enum": [
                "Sunday",
                "Monday",
                "Tuesday",
                "Wednesday",
                "Thursday",
                "Friday",
                "Saturday"
              ]
            },
            "measurementSystem": {
              "type": "string",
              "enum": ["Metric", "Imperial", "Mixed"]
            },
            "activeLegalTenderCurrencies": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["isoAlphaCode"],
                "properties": {
                  "isoAlphaCode": { "type": "string", "pattern": "^[A-Z]{3}$" },
                  "fromDate": { "type": ["string", "null"] }
                }
              }
            },
            "territoryISO31661Alpha2Codes": {
              "type": "array",
              "items": { "type": "string", "pattern": "^[A-Z]{2}$" }
            },
            "spokenLanguages": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["languageCode"],
                "properties": {
                  "languageCode": { "type": "string", "minLength": 2 },
                  "populationPercent": {
                    "type": ["number", "null"],
                    "minimum": 0,
                    "maximum": 100
                  },
                  "officialStatus": { "type": ["string", "null"] },
                  "writingPercent": {
                    "type": ["number", "null"],
                    "minimum": 0,
                    "maximum": 100
                  }
                }
              }
            }
          }
        }
      }
    },
    "OverrideEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "addedAt", "reason", "fields"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Z]{2}$" },
        "addedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "reason": { "type": "string", "minLength": 20 },
        "addedBy": { "type": "string" },
        "fields": {
          "type": "object",
          "description": "Partial Tier 1 SrcDataCountry — only the fields being patched. Missing fields stay as-is from Tier 1.",
          "additionalProperties": true,
          "minProperties": 1
        }
      }
    },
    "RemovalEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "addedAt", "reason"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Z]{2}$" },
        "addedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "reason": { "type": "string", "minLength": 20 },
        "addedBy": { "type": "string" }
      }
    }
  }
}
