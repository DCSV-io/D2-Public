<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <RootNamespace>DcsvIo.D2.Logging</RootNamespace>
    <!--
      Sdk.Web defaults OutputType to Exe (intended for runnable web apps);
      explicit Library override since this is a shared library, NOT an app
      entry point. Sdk.Web is preferred over plain Sdk because it brings the
      AspNetCore framework reference automatically — UseD2RequestLogging needs
      Microsoft.AspNetCore.Builder.IApplicationBuilder + Microsoft.AspNetCore.Http
      types. Plain Sdk + a manual FrameworkReference would be functionally
      equivalent but not the modern convention (matches sibling
      DcsvIo.D2.Telemetry + DcsvIo.D2.AspNetCore csproj; monorepo-private
      DcsvIo.D2.Private.Auth.Http PackageId same Sdk.Web shape).
    -->
    <OutputType>Library</OutputType>
  </PropertyGroup>

  <!--
    DcsvIo.D2.Logging — Serilog configuration + [RedactData] enforcement layer +
    ASP.NET Core request-logging middleware. Open hosts call AddD2Logging
    directly (compose with Telemetry / AspNetCore as needed). Monorepo product
    hosts may also take the private composition root
    DcsvIo.D2.Private.ServiceDefaults (PackageId; not a public install
    and not a future public package) which wires AddD2Logging once so product
    services do not duplicate ~30 lines of LoggerConfiguration boilerplate.

    Does NOT own:
      • OTel SDK setup           — DcsvIo.D2.Telemetry (sibling, ships next)
      • OTLP log-exporter wiring — DcsvIo.D2.Telemetry registers it on
                                   builder.Logging; Serilog routes through the
                                   MEL pipeline via writeToProviders: true.
      • [LoggerMessage] delegates — this lib bootstraps the log pipeline; logging
                                   inside its own bootstrap path would be circular.

    The destructuring policy is the safety net for the [RedactData] attribute
    (defined in DcsvIo.D2.Utilities.Attributes); it intercepts every
    `@`-captured object in any Serilog Log* call across every service that
    wires AddD2Logging. Raw `{prop}` capture (no `@`) bypasses destructuring
    and falls back to .ToString() — see README's "Destructuring discipline".
  -->

  <ItemGroup>
    <PackageReference Include="JetBrains.Annotations" />
    <!--
      Serilog.AspNetCore — the umbrella package. Pulls Serilog,
      Serilog.Extensions.Logging, Serilog.Sinks.Console, and
      Microsoft.Extensions.Logging.Abstractions as transitive deps.
      UseSerilogRequestLogging lives here.
    -->
    <PackageReference Include="Serilog.AspNetCore" />
    <!--
      Serilog.Formatting.Compact — explicit listing for CompactJsonFormatter so
      the dep is visible (prevents transitive removal silently dropping the
      formatter our log pipeline depends on).
    -->
    <PackageReference Include="Serilog.Formatting.Compact" />
    <!--
      Serilog.Enrichers.Environment — provides Enrich.WithMachineName().
      Other enrichers ship with Serilog core (FromLogContext, WithProperty).
    -->
    <PackageReference Include="Serilog.Enrichers.Environment" />
    <!--
      Microsoft.Extensions.{DependencyInjection,Logging,Options}.Abstractions are
      NOT listed — Microsoft.NET.Sdk.Web's framework reference (Microsoft.AspNetCore.App)
      ships them, and adding explicit PackageReferences triggers NU1510. Versions
      are still pinned via Directory.Packages.props.
    -->
  </ItemGroup>

  <ItemGroup>
    <!--
      utilities — [RedactData] attribute + RedactReason enum (consumed by the
      destructuring policy); Falsey() / Truthy() string extensions for options
      validation.
    -->
    <ProjectReference Include="..\utilities\DcsvIo.D2.Utilities.csproj" />
    <!--
      context\abstractions — IRequestContext interface (the strongly-typed
      enricher dep). Foundation-tier; trivial transitive surface.
    -->
    <ProjectReference Include="..\context\abstractions\DcsvIo.D2.Context.Abstractions.csproj" />
    <!--
      aspnetcore — canonical InfrastructurePathMatcher (consumed by
      UseD2RequestLogging's level callback to demote infrastructure-path
      request-completion logs to Verbose). Single source of truth shared
      with DcsvIo.D2.Telemetry's AspNetCore-instrumentation Filter so the
      two libs stay aligned on /health, /alive, /metrics, /.well-known.
    -->
    <ProjectReference Include="..\aspnetcore\DcsvIo.D2.AspNetCore.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="DcsvIo.D2.Tests" />
    <InternalsVisibleTo Include="DcsvIo.D2.Private.Packages.Tests" />
    <!--
      DcsvIo.D2.Private.Edge.Tests — the TypeSpec-emitter validation tests drive the generated
      SignInput record through RedactDataDestructuringPolicy (the real policy,
      not a public facade) to assert [property: RedactData] is wired correctly.
      The public AddD2Logging path mutates the static Log.Logger which is unsafe
      in parallel test runs; direct policy instantiation is the correct seam
      (mirrors the DcsvIo.D2.Tests unit-test pattern) and requires IVT.
    -->
    <InternalsVisibleTo Include="DcsvIo.D2.Private.Edge.Tests" />
  </ItemGroup>

  <!-- Publish metadata (per-package semver + NuGet identity). -->
  <PropertyGroup>
    <Version>0.1.1</Version>
    <PackageId>DcsvIo.D2.Logging</PackageId>
    <Description>Serilog configuration, the [RedactData] PII-enforcement layer, and request-logging middleware for D2 services.</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
