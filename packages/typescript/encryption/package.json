  "dependencies": {
    "@dcsv-io/d2-encryption-abstractions": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.0.18",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
