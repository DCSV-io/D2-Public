{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.d2.dcsv.io/contracts/geo/overlays/subdivisions.overlays.schema.json",
  "title": "Subdivision catalog overlays (trackable manual patches)",
  "description": "Hand-rolled overlay file applied at Tier 2 build time on top of Tier 1 src-data. Used to inject subdivisions that upstream sources (CLDR + debian iso-codes + Wikidata SPARQL) omit AND to override / remove specific entries when upstream is wrong (e.g., CLDR ships a stale label after an ISO reassignment — see IR-22 / Hormozgān). Each entry carries a `reason` + `addedAt` so the policy decision is audit-trail visible. The Tier 2 builder loads overlays after Tier 1 src-data and merges them in before running cross-catalog M:M backfill.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$generated",
    "$source",
    "$schema",
    "$note",
    "catalogVersion",
    "lastEditedAt",
    "additions",
    "overrides",
    "removals"
  ],
  "properties": {
    "$generated": { "const": false },
    "$source": { "const": "manual-overlay" },
    "$schema": { "type": "string" },
    "$note": { "type": "string" },
    "catalogVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.]+)?$"
    },
    "lastEditedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "additions": {
      "type": "array",
      "description": "Subdivisions to ADD that aren't in Tier 1 src-data. Each entry's `data` must match the Tier 1 SrcDataSubdivision shape (the Tier 2 builder handles cross-catalog M:M backfill + denormalization).",
      "items": { "$ref": "#/$defs/AdditionEntry" }
    },
    "overrides": {
      "type": "array",
      "description": "Field-level patches to existing Tier 1 entries. Use sparingly — prefer fixing upstream when possible.",
      "items": { "$ref": "#/$defs/OverrideEntry" }
    },
    "removals": {
      "type": "array",
      "description": "Tier 1 entries to drop from the Tier 2 output. Use rarely — usually a sign the upstream source has a wrong entry we don't want to ship.",
      "items": { "$ref": "#/$defs/RemovalEntry" }
    }
  },
  "$defs": {
    "AdditionEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "addedAt", "reason", "data"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Z]{2}-[A-Z0-9]{1,3}$" },
        "addedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "reason": { "type": "string", "minLength": 20 },
        "addedBy": { "type": "string" },
        "data": {
          "type": "object",
          "description": "Full Tier 1 SrcDataSubdivision shape. The Tier 2 builder ingests this exactly as if it had come from Tier 1 src-data, then runs the standard cross-catalog M:M backfill + denormalization pipeline.",
          "additionalProperties": false,
          "required": [
            "iso31662Code",
            "shortCode",
            "displayName",
            "officialName",
            "countryISO31661Alpha2Code"
          ],
          "properties": {
            "iso31662Code": {
              "type": "string",
              "pattern": "^[A-Z]{2}-[A-Z0-9]{1,3}$"
            },
            "shortCode": { "type": "string", "minLength": 1 },
            "displayName": { "type": "string", "minLength": 1 },
            "officialName": { "type": "string", "minLength": 1 },
            "endonymDisplayName": { "type": ["string", "null"] },
            "countryISO31661Alpha2Code": {
              "type": "string",
              "pattern": "^[A-Z]{2}$"
            },
            "parentISO31662Code": {
              "type": ["string", "null"],
              "pattern": "^[A-Z]{2}-[A-Z0-9]{1,3}$"
            },
            "type": { "type": ["string", "null"] },
            "order": { "type": ["integer", "null"], "minimum": 0 }
          }
        }
      }
    },
    "OverrideEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "addedAt", "reason", "fields"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Z]{2}-[A-Z0-9]{1,3}$" },
        "addedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "reason": { "type": "string", "minLength": 20 },
        "addedBy": { "type": "string" },
        "fields": {
          "type": "object",
          "description": "Partial Tier 1 SrcDataSubdivision — only the fields being patched. Missing fields stay as-is from Tier 1.",
          "additionalProperties": true,
          "minProperties": 1
        }
      }
    },
    "RemovalEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "addedAt", "reason"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Z]{2}-[A-Z0-9]{1,3}$" },
        "addedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "reason": { "type": "string", "minLength": 20 },
        "addedBy": { "type": "string" }
      }
    }
  }
}
