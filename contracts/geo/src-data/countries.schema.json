{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.d2.dcsv.io/contracts/geo/src-data/countries.schema.json",
  "title": "Country catalog (pipeline-raw)",
  "description": "Tier 1 (pipeline-raw) country catalog produced by private/tools/geo-data-pipeline. Verbose with per-entry _provenance + top-level sources / fieldCoverage diagnostics. NOT directly consumed by codegen — see ../countries.schema.json for the Tier 2 codegen-ready shape.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "$note",
    "catalogVersion",
    "generatedAt",
    "sources",
    "fieldCoverage",
    "entries"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "$note": { "type": "string" },
    "catalogVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.]+)?$"
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "sources": { "$ref": "#/$defs/Sources" },
    "fieldCoverage": { "$ref": "#/$defs/FieldCoverage" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["iso31661Alpha2Code", "displayName"],
        "properties": {
          "iso31661Alpha2Code": { "type": "string", "pattern": "^[A-Z]{2}$" },
          "displayName": { "type": "string", "minLength": 1 },
          "widelyAcceptedCurrencies": {
            "type": "array",
            "description": "Optional — currencies widely accepted alongside legal tender at retail/tourism. Populated exclusively via the overlay layer at contracts/geo/overlays/; upstream Tier 1 sources (CLDR / datasets-country-codes) do not provide this.",
            "items": {
              "type": "object",
              "required": ["isoAlphaCode"],
              "properties": {
                "isoAlphaCode": { "type": "string", "pattern": "^[A-Z]{3}$" },
                "fromDate": { "type": ["string", "null"] }
              }
            }
          },
          "touristCurrencies": {
            "type": "array",
            "description": "Optional — currencies accepted in tourist venues but not retail-wide. Populated exclusively via the overlay layer; no upstream Tier 1 source.",
            "items": {
              "type": "object",
              "required": ["isoAlphaCode"],
              "properties": {
                "isoAlphaCode": { "type": "string", "pattern": "^[A-Z]{3}$" },
                "fromDate": { "type": ["string", "null"] }
              }
            }
          },
          "_provenance": { "$ref": "#/$defs/Provenance" }
        }
      }
    }
  },
  "$defs": {
    "Sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "url", "license", "fetchedAt", "sha256"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "license": { "type": "string" },
          "fetchedAt": { "type": "string", "format": "date-time" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "FieldCoverage": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["populated", "total", "pct"],
        "properties": {
          "populated": { "type": "integer", "minimum": 0 },
          "total": { "type": "integer", "minimum": 0 },
          "pct": { "type": "string", "pattern": "^\\d+\\.\\d+%$" }
        }
      }
    },
    "Provenance": {
      "type": "object",
      "description": "Per-entry provenance tracking which upstream source contributed which fields.",
      "additionalProperties": true
    }
  }
}
