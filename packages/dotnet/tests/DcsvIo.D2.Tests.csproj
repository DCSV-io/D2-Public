<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>DcsvIo.D2.Tests</RootNamespace>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <UseMicrosoftTestingPlatformRunner>true</UseMicrosoftTestingPlatformRunner>
    <TestingPlatformDotnetTestSupport>true</TestingPlatformDotnetTestSupport>

    <!--
      Test-project-only warning suppressions. Public-API XML-doc + comment-style
      enforcement remains active for non-test libraries.

      CS1591 (Roslyn) / SA1600 (StyleCop): missing XML doc on public types/members.
      Test method names follow `Method_Scenario_ExpectedResult` which IS the
      documentation; requiring a `summary` echo on every test adds noise.

      SA1512: single-line `//` comments not followed by blank lines. Section
      dividers inside test classes are clearer with a blank line before the next
      test method; SA1512 disagrees. Tests prioritize scan readability over the rule.
    -->
    <!--
      xUnit1051: "use TestContext.Current.CancellationToken on every awaited
      method that accepts a ct" — well-intentioned but exceptionally noisy in
      unit tests that don't model cancellation; xUnit's own timeout already
      bounds runaway tests. Suppressed for clarity.
    -->
    <NoWarn>$(NoWarn);1591;SA1600;SA1512;xUnit1051</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!--
      Microsoft.AspNetCore.App framework reference — required so test code can
      construct AspNetCore primitives (DefaultHttpContext, RouteEndpointBuilder,
      EndpointBuilder, IApplicationBuilder for integration tests, etc.) when
      exercising DcsvIo.D2.Auth.Http (and DcsvIo.D2.Auth.Grpc). Adding via
      FrameworkReference (not a PackageReference) follows the AspNetCore
      conventional opt-in.
    -->
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="xunit.runner.visualstudio">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="AwesomeAssertions" />
    <PackageReference Include="Microsoft.Extensions.TimeProvider.Testing" />
    <PackageReference Include="JetBrains.Annotations" />
    <!--
      Microsoft.Extensions.{DependencyInjection,Logging,Logging.Abstractions,Hosting}
      packages were previously listed here as explicit PackageReferences. They've
      been removed because the test project now declares a FrameworkReference to
      Microsoft.AspNetCore.App (so it can construct AspNetCore primitives for
      DcsvIo.D2.Auth.Http + DcsvIo.D2.Auth.Grpc tests), and the framework
      reference ships those packages — leaving explicit PackageReferences
      triggers NU1510 ("will not be pruned"). Versions are still pinned via
      Directory.Packages.props.
    -->
    <!--
      Microsoft.CodeAnalysis.CSharp — needed by SrcGen integration tests
      (Unit/Auth/SourceGen, Unit/Context/SourceGen) which drive
      CSharpGeneratorDriver against synthetic compilations. The SrcGen csprojs
      mark this PrivateAssets="all" so it doesn't propagate; tests need an
      explicit reference.
    -->
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" />
    <!-- Microsoft.EntityFrameworkCore.InMemory — provider-free in-memory provider used by
         Unit/DataGovernance/EntityFrameworkCore/ model-build-only tests. -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.InMemory" />
    <!-- Npgsql.EntityFrameworkCore.PostgreSQL — relational provider used by the
         AnonymizationTierClassifier model-build-only tests (UseNpgsql with a dummy
         connection string; no live DB connection is ever opened). Required because
         InMemory is a non-relational provider and cannot model column names, JSON
         mappings, or table-splitting — all of which the classifier reads via
         GetColumnName() / IsMappedToJson() / GetTableName(). -->
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" />
    <!-- Testcontainers.Redis — for Integration/Caching/Distributed tests against a real Redis container -->
    <PackageReference Include="Testcontainers.Redis" />
    <!-- Testcontainers.RabbitMq — for Integration/Messaging tests against a real RabbitMQ container -->
    <PackageReference Include="Testcontainers.RabbitMq" />
    <!-- Testcontainers.PostgreSql — for Integration/DataGovernance/AnonymizationEngine
         end-to-end tests: a real PostgreSQL container, EnsureCreated synthetic schema,
         and adversarial Tier-A/B anonymization assertions. -->
    <PackageReference Include="Testcontainers.PostgreSql" />
    <!-- RabbitMQ.Client — for unit tests that need to construct AMQP exception types directly -->
    <PackageReference Include="RabbitMQ.Client" />
    <!-- Microsoft.AspNetCore.TestHost — in-memory web host for end-to-end
         middleware-pipeline tests of DcsvIo.D2.Auth.Http. -->
    <PackageReference Include="Microsoft.AspNetCore.TestHost" />
    <!-- Grpc.Tools — drives protoc + the C# plugin for the test-only
         only; PrivateAssets="all" so the analyzer / build targets do not flow
         to anything that ProjectReferences this csproj. -->
    <PackageReference Include="Grpc.Tools">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <!-- Grpc.Net.Client — client-side channel for the in-process integration
         test (constructs a GrpcChannel atop the TestServer's HttpClient). -->
    <PackageReference Include="Grpc.Net.Client" />
    <!-- Google.Protobuf — runtime types (IMessage, IBufferMessage, etc.)
         consumed by the generated proto code; required to compile the
         Grpc.Tools-emitted source files. -->
    <PackageReference Include="Google.Protobuf" />
    <PackageReference Include="coverlet.msbuild">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

