{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.d2.dcsv.io/contracts/geo/src-data/timezones.schema.json",
  "title": "Timezone catalog (pipeline-raw)",
  "description": "Tier 1 (pipeline-raw) timezone catalog produced by the geo data pipeline Verbose with diagnostics including reconciliation (IANA-vs-ICU drift). NOT directly consumed by codegen — see ../timezones.schema.json for the Tier 2 shape.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "$schema",
    "$note",
    "catalogVersion",
    "generatedAt",
    "sources",
    "fieldCoverage",
    "entries"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "$note": { "type": "string" },
    "catalogVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.]+)?$"
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "sources": { "$ref": "#/$defs/Sources" },
    "fieldCoverage": { "$ref": "#/$defs/FieldCoverage" },
    "reconciliation": {
      "type": "object",
      "description": "Optional diagnostic — drift between IANA tzdb zone list and Node ICU Intl.DateTimeFormat resolution.",
      "additionalProperties": true,
      "properties": {
        "ianaOnlyZones": { "type": "array", "items": { "type": "string" } },
        "icuOnlyZones": { "type": "array", "items": { "type": "string" } }
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["ianaIdentifier"],
        "properties": {
          "ianaIdentifier": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "Sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "url", "license", "fetchedAt", "sha256"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "license": { "type": "string" },
          "fetchedAt": { "type": "string", "format": "date-time" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "FieldCoverage": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["populated", "total", "pct"],
        "properties": {
          "populated": { "type": "integer", "minimum": 0 },
          "total": { "type": "integer", "minimum": 0 },
          "pct": { "type": "string", "pattern": "^\\d+\\.\\d+%$" }
        }
      }
    }
  }
}
