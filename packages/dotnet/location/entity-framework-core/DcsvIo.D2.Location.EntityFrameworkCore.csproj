<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>DcsvIo.D2.Location.EntityFrameworkCore</RootNamespace>
  </PropertyGroup>

  <!--
    Per-VO complex-type and value-converter mapping helpers for the DcsvIo.D2.Location
    value objects (StreetAddress, AdminLocation, Coordinates). Called from the host's
    IEntityTypeConfiguration<T> class — the domain aggregate holds plain VO-typed
    properties and carries zero EF references. Helpers wire HasMaxLength from
    FieldConstraints (DcsvIo.D2.Validation.Abstractions; plus the encoder-intrinsic
    geohash/plus-code caps), value converters (SubdivisionCode struct, CountryCode enum),
    and the per-VO anonymize defaults via the fluent .Anonymize* API on
    DcsvIo.D2.DataGovernance.EntityFrameworkCore.
    NO DbContext, NO migrations, NO DI engine — the host owns those.
    The generic CreateD2Index migration helper lives in DcsvIo.D2.EntityFrameworkCore;
    a host that needs to index a Location complex member references that lib directly.
  -->

  <ItemGroup>
    <ProjectReference Include="..\core\DcsvIo.D2.Location.csproj" />
    <ProjectReference Include="..\..\data-governance\entity-framework-core\DcsvIo.D2.DataGovernance.EntityFrameworkCore.csproj" />
    <!--
      DcsvIo.D2.Validation.Abstractions — FieldConstraints.* length caps
      (STREET_LINE_MAX / CITY_MAX / POSTAL_CODE_MAX) applied by the decorators. Does not
      flow transitively via location/core (which refs geo/abstractions, not validation).
    -->
    <ProjectReference Include="..\..\validation\abstractions\DcsvIo.D2.Validation.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Microsoft.EntityFrameworkCore.Relational — CPM-pinned in Directory.Packages.props.
      Provides ComplexPropertyBuilder<T>, ComplexTypePropertyBuilder<T>, HasMaxLength,
      HasConversion, ValueConverter<,>, and the relational metadata APIs. Base EF Core
      flows transitively via Relational; do NOT add a separate base
      Microsoft.EntityFrameworkCore ref to avoid NU1510. CountryCode / SubdivisionCode
      (DcsvIo.D2.Geo.Abstractions) flow transitively via DcsvIo.D2.Location.
    -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="DcsvIo.D2.Tests" />
  </ItemGroup>

  <!-- Publish metadata (per-package semver + NuGet identity). -->
  <PropertyGroup>
    <Version>0.1.1</Version>
    <PackageId>DcsvIo.D2.Location.EntityFrameworkCore</PackageId>
    <Description>Reusable Entity Framework Core mapping for the DcsvIo.D2.Location value objects, applied via infra IEntityTypeConfiguration.</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
