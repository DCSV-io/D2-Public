{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.d2.dcsv.io/contracts/geo/countries.schema.json",
  "title": "Country catalog (codegen-ready)",
  "description": "Tier 2 codegen-ready Country catalog. Matches the CountrySpec record shape consumed by .NET SourceGen + TS emitter. See the geo data pipeline for the matching TypeScript interface.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$generated",
    "$source",
    "$schema",
    "$note",
    "catalogVersion",
    "generatedAt",
    "entries"
  ],
  "properties": {
    "$generated": { "const": true },
    "$source": { "const": "pipeline-derived" },
    "$schema": { "type": "string" },
    "$note": { "type": "string" },
    "catalogVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.]+)?$"
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/Country" }
    }
  },
  "$defs": {
    "DayOfWeek": {
      "type": "string",
      "enum": [
        "Sunday",
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday"
      ]
    },
    "MeasurementSystem": {
      "type": "string",
      "enum": ["Metric", "Imperial", "Mixed"]
    },
    "CurrencyAcceptanceLevel": {
      "type": "string",
      "enum": ["LegalTender", "WidelyAccepted", "Tourist"]
    },
    "ISO31661Alpha2Code": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "ISO4217AlphaCode": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "ISO6391Code": {
      "type": "string",
      "pattern": "^[a-z]{2,3}$"
    },
    "CountryCurrencyAcceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["iso4217AlphaCode", "level"],
      "properties": {
        "iso4217AlphaCode": { "$ref": "#/$defs/ISO4217AlphaCode" },
        "level": { "$ref": "#/$defs/CurrencyAcceptanceLevel" }
      }
    },
    "Country": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "iso31661Alpha2Code",
        "iso31661Alpha3Code",
        "iso31661NumericCode",
        "displayName",
        "officialName",
        "endonymDisplayName",
        "phoneNumberPrefix",
        "phoneNumberNationalFormat",
        "phoneNumberMinDigits",
        "phoneNumberMaxDigits",
        "firstDayOfWeek",
        "weekendStart",
        "weekendEnd",
        "measurementSystem",
        "primaryLanguageISO6391Code",
        "primaryCurrencyISO4217AlphaCode",
        "primaryLocaleIETFBCP47Tag",
        "sovereignCountryISO31661Alpha2Code",
        "geopoliticalEntityShortCodes",
        "subdivisionISO31662Codes",
        "timezoneIanaIdentifiers",
        "localeIETFBCP47Tags",
        "spokenLanguageISO6391Codes",
        "territoryISO31661Alpha2Codes",
        "currencies"
      ],
      "properties": {
        "iso31661Alpha2Code": { "$ref": "#/$defs/ISO31661Alpha2Code" },
        "iso31661Alpha3Code": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "iso31661NumericCode": { "type": "string", "pattern": "^\\d{3}$" },
        "displayName": { "type": "string", "minLength": 1 },
        "officialName": { "type": "string", "minLength": 1 },
        "endonymDisplayName": { "type": ["string", "null"] },
        "phoneNumberPrefix": { "type": ["string", "null"] },
        "phoneNumberNationalFormat": { "type": ["string", "null"] },
        "phoneNumberMinDigits": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 17
        },
        "phoneNumberMaxDigits": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 17
        },
        "firstDayOfWeek": { "$ref": "#/$defs/DayOfWeek" },
        "weekendStart": { "$ref": "#/$defs/DayOfWeek" },
        "weekendEnd": { "$ref": "#/$defs/DayOfWeek" },
        "measurementSystem": { "$ref": "#/$defs/MeasurementSystem" },
        "primaryLanguageISO6391Code": {
          "oneOf": [{ "$ref": "#/$defs/ISO6391Code" }, { "type": "null" }]
        },
        "primaryCurrencyISO4217AlphaCode": {
          "oneOf": [{ "$ref": "#/$defs/ISO4217AlphaCode" }, { "type": "null" }]
        },
        "primaryLocaleIETFBCP47Tag": { "type": ["string", "null"] },
        "sovereignCountryISO31661Alpha2Code": {
          "oneOf": [
            { "$ref": "#/$defs/ISO31661Alpha2Code" },
            { "type": "null" }
          ]
        },
        "geopoliticalEntityShortCodes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "subdivisionISO31662Codes": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Z]{2}-[A-Z0-9]{1,3}$" }
        },
        "timezoneIanaIdentifiers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "localeIETFBCP47Tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 }
        },
        "spokenLanguageISO6391Codes": {
          "type": "array",
          "items": { "$ref": "#/$defs/ISO6391Code" }
        },
        "territoryISO31661Alpha2Codes": {
          "type": "array",
          "items": { "$ref": "#/$defs/ISO31661Alpha2Code" }
        },
        "currencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/CountryCurrencyAcceptance" }
        }
      }
    }
  }
}
