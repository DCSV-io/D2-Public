<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>DcsvIo.D2.Caching.Local.Default</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="JetBrains.Annotations" />
    <PackageReference Include="Microsoft.Extensions.Caching.Memory" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\abstractions\DcsvIo.D2.Caching.Abstractions.csproj" />
    <ProjectReference Include="..\..\result\core\DcsvIo.D2.Result.csproj" />
    <ProjectReference Include="..\..\i18n\abstractions\DcsvIo.D2.I18n.Abstractions.csproj" />
    <ProjectReference Include="..\..\i18n\keys\DcsvIo.D2.I18n.Keys.csproj" />
    <ProjectReference Include="..\..\utilities\DcsvIo.D2.Utilities.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="DcsvIo.D2.Tests" />
  </ItemGroup>

  <!-- Publish metadata (per-package semver + NuGet identity). -->
  <PropertyGroup>
    <Version>0.1.1</Version>
    <PackageId>DcsvIo.D2.Caching.Local.Default</PackageId>
    <Description>Default per-process ILocalCache implementation for D2, wrapping Microsoft.Extensions.Caching.Memory with in-process lock state.</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
