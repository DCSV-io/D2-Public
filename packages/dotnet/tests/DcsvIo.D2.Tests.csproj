    <ProjectReference Include="..\entity-framework-core\postgres\DcsvIo.D2.EntityFrameworkCore.Postgres.csproj" />
    <!--
      DcsvIo.D2.AdvisoryLocks.SourceGen — referenced as a normal library (not an
