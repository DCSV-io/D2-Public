<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>DcsvIo.D2.Validation.Abstractions</RootNamespace>

    <!--
      Emit the SrcGen-emitted FieldConstraints.g.cs + Taxonomy.g.cs (driven by the
      validation/source-gen analyzer wired below) to <project-dir>/Generated/.
      The directory is tracked in git so PR reviewers see codegen diffs without
      a local build.
    -->
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>Generated</CompilerGeneratedFilesOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <!--
      The SourceGen pipeline feeds the in-memory compiler with the same content
      that lands on disk under Generated/. Without this Remove, the SDK-default
      <Compile Include="**/*.cs" /> glob picks up the on-disk copy and the build
      fails with duplicate-definition errors (CS0101 / CS0111). See:
      https://learn.microsoft.com/dotnet/core/project-sdk/msbuild-props#compilergeneratedfilesoutputpath
    -->
    <Compile Remove="$(CompilerGeneratedFilesOutputPath)\**\*.cs" />
  </ItemGroup>

  <!--
    DI-free interface + shared-catalog library. Domain code anywhere in the
    backend can take a ProjectReference here without pulling in a DI container,
    phone-number library, or geo catalog data. The surface is the three
    validator contracts plus the shared field-constraints catalog (the emitted
    FieldConstraints constants + NamePrefix / NameSuffix / BiologicalSex taxonomy
    enums) — the lowest shared vocabulary layer every consumer depends on.

    NO Microsoft.Extensions.DependencyInjection reference.
    NO implementation code — implementations live in DcsvIo.D2.Validation.
  -->
  <ItemGroup>
    <!--
      DcsvIo.D2.Result — all three validator interfaces return D2Result<string>
      so callers can branch on Success / ValidationFailed and surface field-level
      InputErrors via the standard envelope.
    -->
    <ProjectReference Include="..\..\result\core\DcsvIo.D2.Result.csproj" />
    <!--
      DcsvIo.D2.Geo.Abstractions — CountryCode is used by IPhoneValidator
      (defaultRegion) and IPostalCodeValidator (countryCode) to scope
      national-format interpretation and country-specific format rules.
    -->
    <ProjectReference Include="..\..\geo\abstractions\DcsvIo.D2.Geo.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Source generator driving the codegen-emitted FieldConstraints + taxonomy
      enums. The spec file is surfaced via AdditionalFiles so the SrcGen can
      read it at codegen time. Single-target dispatch on
      DcsvIo.D2.Validation.Abstractions.
    -->
    <ProjectReference Include="..\source-gen\DcsvIo.D2.Validation.SourceGen.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
    <AdditionalFiles Include="$(D2PublicContractsRoot)validation\field-constraints.spec.json" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="DcsvIo.D2.Tests" />
  </ItemGroup>

  <!-- Publish metadata (per-package semver + NuGet identity). -->
  <PropertyGroup>
    <Version>0.1.1</Version>
    <PackageId>DcsvIo.D2.Validation.Abstractions</PackageId>
    <Description>Validation contract surface for D2 — email, phone, and postal-code validator interfaces, shared field-length bounds, and the name/sex taxonomy enums.</Description>
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
