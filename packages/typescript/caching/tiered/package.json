    "type-check:test": "tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "@dcsv-io/d2-caching-abstractions": "workspace:*",
    "@dcsv-io/d2-logging": "workspace:*",
    "@dcsv-io/d2-result": "workspace:*"
  },
  "devDependencies": {
    "@dcsv-io/d2-caching-distributed-redis": "workspace:*",
    "@dcsv-io/d2-caching-local-default": "workspace:*",
    "@testcontainers/redis": "11.14.0",
    "@vitest/coverage-v8": "4.0.18",
    "testcontainers": "11.14.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
