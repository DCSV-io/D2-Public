{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.d2.dcsv.io/contracts/geo/src-data/subdivisions.schema.json",
  "title": "Subdivision catalog (pipeline-raw)",
  "description": "Tier 1 (pipeline-raw) subdivision catalog produced by the geo data pipeline Verbose with per-entry _provenance + top-level diagnostics. NOT directly consumed by codegen — see ../subdivisions.schema.json for the Tier 2 codegen-ready shape.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "$schema",
    "$note",
    "catalogVersion",
    "generatedAt",
    "sources",
    "fieldCoverage",
    "entries"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "$note": { "type": "string" },
    "catalogVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.]+)?$"
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "sources": { "$ref": "#/$defs/Sources" },
    "fieldCoverage": { "$ref": "#/$defs/FieldCoverage" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["iso31662Code", "countryISO31661Alpha2Code"],
        "properties": {
          "iso31662Code": {
            "type": "string",
            "pattern": "^[A-Z]{2}-[A-Z0-9]{1,3}$"
          },
          "countryISO31661Alpha2Code": {
            "type": "string",
            "pattern": "^[A-Z]{2}$"
          }
        }
      }
    }
  },
  "$defs": {
    "Sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "url", "license", "fetchedAt", "sha256"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "license": { "type": "string" },
          "fetchedAt": { "type": "string", "format": "date-time" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "FieldCoverage": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["populated", "total", "pct"],
        "properties": {
          "populated": { "type": "integer", "minimum": 0 },
          "total": { "type": "integer", "minimum": 0 },
          "pct": { "type": "string", "pattern": "^\\d+\\.\\d+%$" }
        }
      }
    }
  }
}
